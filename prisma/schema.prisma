generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id
  email        String   @unique
  firstName    String? // Prénom
  lastName     String? // Nom
  companyName  String? // Nom de l'entreprise
  businessType String?
  vibe         String[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  editing_level       String?  // Ex: "debutant", "intermediaire"
  camera_people       String?  // Nombre de personnes (String ou Int selon ce que tu avais)
  city                String?  // Ex: "Paris" ou "En ligne"
  production_capacity String?  // Ex: "1-2", "3-4"
  best_seller         String?  // Ex: "Pose complète volume russe"
}

model Video {
  id        String   @id @default(cuid())
  title     String // Ajoute bien ce champ !
  url       String // C'est le lien embed
  platform  String // "tiktok" ou "instagram"
  views     Int      @default(0)
  likes     Int      @default(0)
  difficulty      String   // "debutant", "intermediaire", "avance", "sans_montage"
  camera_presence String   // "face_cam", "multi", "b_roll"
  sector_scope    String   // "generic" ou "specific"
  compatible_sectors String[] // Ex: ["Beauté", "Restauration"]
  business_goal   String   // "visibilite", "expertise", "conversion"
  video_format    String   // "avant_apres", "trend", "conseil"
  estimated_time  String?  // "15 - 30 sec"
  category  String // Pour le filtrage (ex: Restaurateur)
  vibe      String[] // Pour le filtrage (ex: Dynamique)
  tags      Tag[]
  createdAt DateTime @default(now())
}

model Tag {
  id     String  @id @default(cuid())
  name   String  @unique
  type   TagType
  videos Video[]
}

enum TagType {
  NICHE
  FORMAT
}

model GeneratedScript {
  id        String   @id @default(cuid())
  userId    String
  videoId   String
  hook      String
  script    String[]
  cta       String
  createdAt DateTime @default(now())

  @@unique([userId, videoId]) // Pour qu'un utilisateur n'ait qu'un seul script par vidéo
}
